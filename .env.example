# Pick one: openai, openai-compatible, openai-responses, kimi, moonshot, anthropic, gemini, ollama
LLM_PROVIDER=kimi

# Kimi Code / Kimi CLI subscription
KIMI_API_KEY=sk-...
KIMI_MODEL=kimi-for-coding
KIMI_BASE_URL=https://api.kimi.com/coding/v1

# Moonshot / Kimi Platform API
MOONSHOT_API_KEY=sk-...
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Custom OpenAI-compatible proxy / relay example:
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=your-proxy-key
# OPENAI_MODEL=your-proxy-model
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# Custom OpenAI Responses API proxy / relay example:
# LLM_PROVIDER=openai-responses
# OPENAI_API_KEY=your-proxy-key
# OPENAI_MODEL=your-proxy-model
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

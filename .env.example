# Pick one: openai, openai-compatible, openai-completions, openai-responses, codex-chatgpt, kimi, moonshot, anthropic, gemini, ollama
LLM_PROVIDER=kimi

# Local Codex ChatGPT login
# Reads ~/.codex/auth.json and calls https://chatgpt.com/backend-api/codex/responses.
CODEX_MODEL=gpt-5.5
CODEX_CHATGPT_BASE_URL=https://chatgpt.com/backend-api/codex

# Kimi Code / Kimi CLI subscription
KIMI_API_KEY=sk-...
KIMI_MODEL=kimi-for-coding
KIMI_BASE_URL=https://api.kimi.com/coding/v1

# Moonshot / Kimi Platform API
MOONSHOT_API_KEY=sk-...
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Generic relay variables. These can be used with openai, openai-compatible,
# openai-responses, anthropic, or gemini providers instead of provider-specific
# API key/model/base URL names. When set, LLM_* values take priority over
# provider-specific variables such as OPENAI_*.
# LLM_API_KEY=your-relay-key
# LLM_MODEL=your-relay-model
# LLM_BASE_URL=https://your-relay.example.com/v1
# Set false for Chat Completions relays/models that reject tools/tool_choice.
# LLM_NATIVE_TOOLS=false

# Custom OpenAI-compatible proxy / relay example:
# LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=your-proxy-key
# OPENAI_MODEL=your-proxy-model
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# Custom OpenAI Responses API proxy / relay example:
# LLM_PROVIDER=openai-responses
# OPENAI_API_KEY=your-proxy-key
# OPENAI_MODEL=your-proxy-model
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# Generic relay examples:
# LLM_PROVIDER=openai-responses
# LLM_API_KEY=your-relay-key
# LLM_MODEL=your-responses-model
# LLM_BASE_URL=https://relay.example.com/v1
#
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your-relay-key
# LLM_MODEL=your-anthropic-compatible-model
# LLM_BASE_URL=https://relay.example.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional remote MCP client configuration for spa agentLoop.
# Single streamable HTTP MCP server:
# SPA_MCP_NAME=browser
# SPA_MCP_URL=http://127.0.0.1:8000/mcp
# SPA_MCP_AUTH_TOKEN=your-token

# Or multiple streamable HTTP MCP servers:
# SPA_MCP_SERVERS=[{"name":"browser","url":"http://127.0.0.1:8000/mcp"},{"name":"target","url":"http://127.0.0.1:8001/mcp","auth_token":"your-token"}]
